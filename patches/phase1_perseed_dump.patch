+import os as _os, json as _json
+def _dump_perseed(args, task, metrics_dict):
+    """Env-gated: if DHG_DUMP_DIR set, write per-seed metric vectors to JSON.
+    metrics_dict[m] = list (len=num_seeds) of per-seed vectors; test col = index -1."""
+    d=_os.environ.get("DHG_DUMP_DIR")
+    if not d: return
+    out=_os.path.join(d, task, str(args.dname))
+    _os.makedirs(out, exist_ok=True)
+    payload={"method":args.method,"dataset":args.dname,"task":task,
+             "num_seeds":int(args.num_seeds),"metrics":{}}
+    for m,vals in metrics_dict.items():
+        payload["metrics"][m]=[[float(x) for x in (v if hasattr(v,"__len__") else [v])] for v in vals]
+    with open(_os.path.join(out, f"{args.method}.json"),"w") as f:
+        _json.dump(payload,f,indent=1)
+
